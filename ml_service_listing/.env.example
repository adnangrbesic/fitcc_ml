API_BASE_URL=http://localhost:5000
API_KEY=secret
API_KEY_HEADER=X-API-Key
UNSCORED_ENDPOINT=/api/listings/unscored
SCORE_ENDPOINT=/api/listings/score-n
SCORE_PAYLOAD_MODE=map
REQUEST_TIMEOUT_SECONDS=10
BATCH_SIZE=50
LOG_LEVEL=INFO
VERIFY_SSL=true
POLL_INTERVAL_SECONDS=300
MODEL_PATH=ml_service_listing/model/model.cbm
TRAINING_DATA_PATH=ml_service_listing/training/data/listings.json
RETRAIN_ENABLED=true
RETRAIN_ITERATIONS=50
